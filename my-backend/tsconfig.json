{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "types": ["node", "jest"],
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2023",
    "rootDir": "./src",
    "outDir": "./dist",
    "strictNullChecks": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "**/*.spec.ts", "**/*e2e-spec.ts"]
}
